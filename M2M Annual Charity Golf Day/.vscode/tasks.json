{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: dev server",
      "type": "shell",
      "command": "uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend: dev server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Dev: backend and frontend",
      "dependsOn": ["Backend: dev server", "Frontend: dev server"],
      "problemMatcher": []
    }
  ]
}
